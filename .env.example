# Configurações do Banco de Dados
DATABASE_URL="postgres://usuario:senha@localhost:5432/hospital_file_manager"

# Ambiente
NODE_ENV="development"
VITE_APP_ID="app_id_aqui"
JWT_SECRET="segredo_super_seguro_para_tokens"
OWNER_OPEN_ID="owner_id_aqui"

# Supabase (Autenticação/Armazenamento se aplicável)
VITE_SUPABASE_URL="https://sua-url-aqui.supabase.co"
VITE_SUPABASE_ANON_KEY="sua_chave_anon_aqui"

# Integração Banco Inter
INTER_CLIENT_ID=""
INTER_CLIENT_SECRET=""
INTER_CERT_PEM=""
INTER_KEY_PEM=""
INTER_CONTA_CORRENTE=""
INTER_BASE_URL="https://cdpj.partners.bancointer.com.br"

# Banco Warleine (Sincronização)
WARLEINE_DB_HOST="localhost"
WARLEINE_DB_PORT="5432"
WARLEINE_DB_NAME="warleine_db"
WARLEINE_DB_USER="postgres"
WARLEINE_DB_PASSWORD="password"

# Atendimentos PG
PG_ATENDIMENTOS_HOST="localhost"
PG_ATENDIMENTOS_PORT="5432"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# Configurações de SMTP Email
SMTP_HOST="smtp.exemplo.com"
SMTP_PORT="587"
SMTP_USER="usuario@exemplo.com"
SMTP_PASS="senha_aqui"

# Módulos Ativos do Sistema (true/false)
ENABLE_MODULO_FATURAMENTO="true"
ENABLE_MODULO_GLOSA="true"
ENABLE_MODULO_COMPARACOES="true"
ENABLE_MODULO_MOTOR_REGRAS="true"
ENABLE_MODULO_TASY="true"
ENABLE_MODULO_RELATORIOS="true"

# Outros
OAUTH_SERVER_URL=""
BUILT_IN_FORGE_API_URL=""
BUILT_IN_FORGE_API_KEY=""
